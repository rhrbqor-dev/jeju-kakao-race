# 필수: Supabase/Render/Postgres의 연결 문자열
DATABASE_URL=postgresql://postgres.xxxxx:YOUR_PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

# 필수: 관리자 화면 비밀번호. 반드시 바꾸세요.
ADMIN_PASSWORD=change-this-admin-password

# 선택: 카카오 스킬 요청 검증용 비밀키. 오픈빌더 스킬 URL에 ?key=값 으로 붙여 사용할 수 있습니다.
KAKAO_SKILL_KEY=change-this-kakao-key

# Render 배포 후 자동으로 잡힙니다. 로컬 테스트는 3000 사용.
PORT=3000

# 배포된 서비스 주소. 비워두면 요청 호스트 기준으로 자동 생성합니다.
PUBLIC_BASE_URL=
